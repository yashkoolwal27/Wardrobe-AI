# ==============================================================================
# Wardrobe AI — Environment Configuration Example
# Copy this file to .env and fill in your developer keys.
# ==============================================================================

# ─── Gemini AI Studio ─────────────────────────────────────────────────────────
# Obtain a free key from https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ─── Supabase (Database & Auth Source of Truth) ────────────────────────────────
# From your Supabase project dashboard -> Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# ─── Cloudinary (Clothing item photos storage) ─────────────────────────────────
# From your Cloudinary Dashboard -> Product Environment Settings -> Credentials
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset_here

# ─── Firebase Storage (Generated outfit lookbook saves) ───────────────────────
# From your Firebase Console -> Project Settings -> General -> Web Apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
